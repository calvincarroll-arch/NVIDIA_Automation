# --- 1. The Mock Data (Coursera provides this under the hood) ---
class Event:
    def __init__(self, event_date, event_type, machine_name, user):
        self.date = event_date
        self.type = event_type
        self.machine = machine_name
        self.user = user

# A chaotic, unsorted list of server logs
events = [
    Event('2026-06-02 12:00:00', 'login', 'DFW-WEB-01', 'ccarroll'),
    Event('2026-06-02 12:05:00', 'login', 'DFW-DB-02', 'admin_sarah'),
    Event('2026-06-02 12:30:00', 'logout', 'DFW-WEB-01', 'ccarroll'),
    Event('2026-06-02 13:00:00', 'login', 'DFW-WEB-01', 'dev_mike'),
    Event('2026-06-02 13:15:00', 'logout', 'DFW-DB-02', 'admin_sarah'),
    Event('2026-06-02 13:20:00', 'login', 'DFW-DB-02', 'admin_sarah')
]

# --- 2. The Sorting Helper ---
def get_event_date(event):
    """Helper function to sort the logs chronologically."""
    return event.date


# --- 3. The Core Logic Engine (YOUR JOB) ---
def current_users(events):
    # Step A: Sort the events chronologically so logouts don't happen before logins
    events.sort(key=get_event_date)
    
    # Step B: Initialize your tracking scoreboard (The Dictionary)
    # This will look like: {"DFW-WEB-01": {"dev_mike"}, "DFW-DB-02": {"admin_sarah"}}
    machines = {}
    
    # Step C: The Iteration Engine
    for event in events:
        # Pitfall Trap: If the machine isn't in our dictionary yet, we must initialize it!
        # We initialize it with a 'set' because sets don't allow duplicate logins.
        if event.machine not in machines:
            machines[event.machine] = set()
            
        # Step D: The Logic Gates
        if event.type == "login":
            machines[event.machine].add(event.user)
            
        elif event.type == "logout":
            # Safety Trap: Only remove the user if they are actually in the set!
            if event.user in machines[event.machine]:
                machines[event.machine].remove(event.user)
                
    return machines


# --- 4. The Report Generator (YOUR JOB) ---
def generate_report(machines):
    """Takes the compiled dictionary and prints a clean report."""
    print("[*] --- DAILY MACHINE USAGE REPORT --- [*]")
    
    # Step A: Unpack the dictionary
    for machine, users in machines.items():
        
        # Step B: Filter out empty machines! 
        # If everyone logged out, the set is empty. We don't print empty machines.
        if len(users) > 0:
            # Step C: Format the output cleanly
            user_list = ", ".join(users)
            print(f"{machine}: {user_list}")


# --- Execution ---
if __name__ == "__main__":
    # 1. Process the logs into a dictionary
    active_machines = current_users(events)
    
    # 2. Feed the dictionary into the report generator
    generate_report(active_machines)

