import unittest

# This is our tiny "Unit"
def get_greeting(name):
    if not name:
        return "Hello, Friend!"
    return f"Hello, {name}!"

# Our testing suite for this one unit
class TestGreeting(unittest.TestCase):
    
    def test_greeting_with_name(self):
        # We test just this one specific scenario
        self.assertEqual(get_greeting("Alice"), "Hello, Alice!")
        
    def test_greeting_no_name(self):
        # We test what happens if we give it nothing
        self.assertEqual(get_greeting(""), "Hello, Friend!")

if __name__ == '__main__':
    unittest.main()


